{
  "name": "scout-film-location-ai",
  "version": "1.0.0",
  "description": "AI Film Location Scout powered by Gemini Live API - Google Hackathon 2025",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server.js"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.0"
  }
}
