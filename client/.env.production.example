# Copy to .env.production.local and fill in your deployed backend URLs

# GitHub Pages base path — must match your repo name (e.g. /Vantage)
VITE_BASE_PATH=/your-repo-name

# WebSocket URL of your deployed backend (Railway / Render / Fly.io)
VITE_WS_URL=wss://your-backend.railway.app

# HTTP API base URL of your deployed backend
VITE_API_URL=https://your-backend.railway.app
